#~ "'first'/'open': 使用合并区间的第一个值。如：         [(1, 2, 3), (4, 5), (6, 7)] 合并后变为: "
#~ "[(1), (4), (6)]     - 'max'/'high': 使用合并区间的最大值作为合并值：         [(1, 2, 3), (4,"
#~ " 5), (6, 7)] 合并后变为: [(3), (5), (7)]     - 'min'/'low': 使用合并区间的最小值作为合并值："
#~ "         [(1, 2, 3), (4, 5), (6, 7)] 合并后变为: [(1), (4), (6)]     - "
