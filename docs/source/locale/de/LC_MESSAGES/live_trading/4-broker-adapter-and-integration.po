msgid "`accepted=True`"
msgstr "`accepted=True`"

#: ../../source/live_trading/4-broker-adapter-and-integration.md
msgid "继续流转"
msgstr "Weiter verbreiten"

#: ../../source/live_trading/4-broker-adapter-and-integration.md
msgid "**回写**券商号与名称"
msgstr "**Bitte zurückschreiben:** Maklerfirmennummer und -name"

