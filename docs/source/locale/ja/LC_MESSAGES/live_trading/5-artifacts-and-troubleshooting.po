msgstr "システム動作ログ"

#: ../../source/live_trading/5-artifacts-and-troubleshooting.md
msgid "任务调度、启动门禁、trace、一般报错"
msgstr "タスクのスケジューリング、アクセス制御のアクティブ化、トレース、一般的なエラーのレポート"

#: ../../source/live_trading/5-artifacts-and-troubleshooting.md
msgid "`trade_log`"
msgstr "`trade_log`"

#: ../../source/live_trading/5-artifacts-and-troubleshooting.md
msgid "交易明细 CSV"
msgstr "取引詳細CSV"

#: ../../source/live_trading/5-artifacts-and-troubleshooting.md
msgid "成交、费用、持仓变化明细"
msgstr "取引、手数料、ポジションの変更の詳細"

#: ../../source/live_trading/5-artifacts-and-troubleshooting.md
msgid "`break_point`"
msgstr "`break_point`"

#: ../../source/live_trading/5-artifacts-and-troubleshooting.md
msgid "断点恢复文件（键名是 `break_point`）"
msgstr "ファイルをブレークポイントから再開します (キー名は `break_point`)"

#: ../../source/live_trading/5-artifacts-and-troubleshooting.md
msgid "异常退出后想恢复 Trader 状态"
msgstr "異常終了後に Trader ステータスを復元するにはどうすればよいですか?"

#: ../../source/live_trading/5-artifacts-and-troubleshooting.md
