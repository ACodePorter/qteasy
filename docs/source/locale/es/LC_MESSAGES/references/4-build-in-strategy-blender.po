msgstr "`and`"

#: ../../source/references/4-build-in-strategy-blender.md
msgid "支持`'&"
msgstr "Soporta `&"

#: ../../source/references/4-build-in-strategy-blender.md
msgid "函数"
msgstr "Funciones"

#: ../../source/references/4-build-in-strategy-blender.md
