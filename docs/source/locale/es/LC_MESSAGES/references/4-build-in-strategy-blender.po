msgstr "`sum()`"

#: ../../source/references/4-build-in-strategy-blender.md
msgid "支持的函数参见后表"
msgstr "Las funciones admitidas se enumeran en la siguiente tabla"

#: ../../source/references/4-build-in-strategy-blender.md
msgid "括号"
msgstr "Peréntesis"

