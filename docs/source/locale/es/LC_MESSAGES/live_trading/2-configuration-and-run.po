"or list: - str: 'open, high, low, close' - list: ['open', 'high', 'low', "
"'close'] - list: ['open', 'high', 'low', 'close'] - list: ['open', 'high', "
"'low', 'close'] 'high', 'low', 'close']"

#: ../../source/live_trading/2-configuration-and-run.md
