msgstr "``live_trade_broker_type``"

#: ../../source/live_trading/2-configuration-and-run.md
msgid "券商类型，初学用 `simulator`"
msgstr "Tipos de firmas de corretaje, uso para principiantes `simulator`"

#: ../../source/live_trading/2-configuration-and-run.md
msgid "无成交通道"
msgstr "Sin canal de transacciones"

#: ../../source/live_trading/2-configuration-and-run.md
