msgstr ""
"``u``: ``float``, décalage de la piste supérieure en multiples de l'écart "
"type, par ex. 2 signifie décalage supérieur 2 fois l'écart type"

#: of qteasy.built_in.BBand:10
msgid "``d``: ``float``，下轨偏移量，单位为标准差的倍数，如2表示下偏移2倍标准差"
msgstr ""
"``d``: ``float``, décalage de piste inférieur en multiples de l'écart type, "
"par ex. 2 signifie un décalage inférieur de 2 fois l'écart type"

#: of qteasy.built_in.BBand:14
msgid "计算``BBAND``，检查价格是否超过``BBAND``的上轨或下轨:"
msgstr ""
"Calculez le ``BBAND`` and check whether the price exceeds the upper or lower"
" rail of the ``BBAND``."

#: of qteasy.built_in.BBand:16
msgid "1，当价格上穿上轨时，产生全仓买入信号"
msgstr ""
"1, lorsque le prix monte par le rail supérieur, générant un signal d'achat "
"complet"

#: of qteasy.built_in.BBand:18
msgid "2，当价格下穿下轨时，产生全仓卖出信号``"
msgstr ""
"2, Lorsque le prix descend en dessous du rail inférieur, un signal de vente "
"complet est généré ``"

#: of qteasy.built_in.BBand:20
msgid "默认参数: ``(20, 2, 2)``"
msgstr "Paramètres par défaut : ``(20, 2, 2)``"

#: of qteasy.built_in.BBand:26
msgid "参数范围: ``[(2, 100), (0.5, 5), (0.5, 5)]``"
msgstr "Plage de paramètres : ``[(2, 100), (0.5, 5), (0.5, 5)]``"

