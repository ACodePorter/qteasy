#: of qteasy.core.get_table_info:1
msgid "获取并打印数据源中一张数据表的信息，包括数据量、占用磁盘空间、主键名称、内容以及数据列的名称、数据类型及说明"
msgstr ""
"Récupérez et imprimez des informations sur une table de données dans la "
"source de données, notamment le volume de données, l'utilisation de l'espace"
" disque, le nom de la clé primaire, le contenu, ainsi que les noms, les "
"types de données et les descriptions des colonnes de données."

#: of qteasy.core.get_table_info:3
msgid "需要查询的数据表名称"
msgstr "Nom de la table de données à interroger"

#: of qteasy.core.get_table_info:5
msgid "需要获取数据表信息的数据源，默认None，此时获取QT_DATA_SOURCE的信息"
msgstr ""
"La source de données pour obtenir les informations de la table de données, "
"par défaut Aucune, à ce stade, obtenez les informations QT_DATA_SOURCE"

#: of qteasy.core.get_table_info:7
msgid "是否打印完整数据列名称及类型清单"
msgstr ""
"Si vrai, imprimez la liste complète des noms et types de colonnes de données"

#: of qteasy.core.get_table_info:10
msgid ""
"**data_struct** -- 数据表的结构化信息： {     table name:    数据表名称     table_exists:  "
"bool，数据表是否存在     table_size:    int/str，数据表占用磁盘空间，human 为True时返回容易阅读的字符串"
"     table_rows:    int/str，数据表的行数，human 为True时返回容易阅读的字符串     primary_key1:"
"  str，数据表第一个主键名称     pk_count1:     int，数据表第一个主键记录数量     pk_min1:       "
"obj，数据表主键1起始记录     pk_max1:       obj，数据表主键2最终记录     primary_key2:  "
"str，数据表第二个主键名称     pk_count2:     int，数据表第二个主键记录     pk_min2:       "
"obj，数据表主键2起始记录     pk_max2:       obj，数据表主键2最终记录 }"
msgstr ""
"**data_struct** -- Informations structurées sur la table de données :\n"
"{\n"
"    table_name : nom de la table de données\n"
"    table_exists : bool, si la table de données existe\n"
"    table_size : int/str, espace disque utilisé par la table ; lorsque human est True, renvoie une chaîne lisible par l'homme\n"
"    table_rows : int/str, nombre de lignes dans le tableau ; lorsque human est True, renvoie une chaîne lisible par l'homme\n"
"    Primary_key1 : str, nom de la première clé primaire\n"
"    pk_count1 : int, nombre d'enregistrements pour la première clé primaire\n"
"    pk_min1 : obj, enregistrement de départ pour la clé primaire 1\n"
"    pk_max1 : obj, enregistrement de fin pour la clé primaire 1\n"
"    Primary_key2 : str, nom de la deuxième clé primaire\n"
"    pk_count2 : int, nombre d'enregistrements pour la deuxième clé primaire\n"
"    pk_min2 : obj, enregistrement de départ pour la clé primaire 2\n"
"    pk_max2 : obj, enregistrement de fin pour la clé primaire 2\n"
"}"

#: of qteasy.core.get_table_info:10
msgid "**data_struct** -- 数据表的结构化信息： {"
msgstr ""
"**data_struct** -- Informations structurées sur la table de données : {"

#: of qteasy.core.get_table_info:12
msgid ""
"table name:    数据表名称 table_exists:  bool，数据表是否存在 table_size:    "
"int/str，数据表占用磁盘空间，human 为True时返回容易阅读的字符串 table_rows:    int/str，数据表的行数，human"
" 为True时返回容易阅读的字符串 primary_key1:  str，数据表第一个主键名称 pk_count1:     "
"int，数据表第一个主键记录数量 pk_min1:       obj，数据表主键1起始记录 pk_max1:       obj，数据表主键2最终记录"
" primary_key2:  str，数据表第二个主键名称 pk_count2:     int，数据表第二个主键记录 pk_min2:       "
"obj，数据表主键2起始记录 pk_max2:       obj，数据表主键2最终记录"
msgstr ""
"table name : nom de la table de données table_exists : bool, si la table de "
"données existe table_size : int/str, espace disque occupé par la table de "
"données, humain Si True, renvoie une chaîne facile à lire table_rows : "
"int/str, nombre de lignes dans la table de données, humain Si True, renvoie "
"une chaîne facile à lire Primary_key1 : str, nom de la première clé primaire"
" de la table de données pk_count1 : int, nombre d'enregistrements de la "
"première clé primaire de la table de données pk_min1 : obj, enregistrement "
"de départ de la clé primaire 1 de la table de données pk_max1 : obj, "
"enregistrement final de la clé primaire 2 de la table de données "
"Primary_key2 : str, nom de la deuxième clé primaire de la table de données "
"pk_count2 : int, nombre d'enregistrements de la deuxième clé primaire de la "
"table de données pk_min2 : obj, enregistrement de départ de la clé primaire "
"2 de la table de données pk_max2 : obj, enregistrement final de la clé "
"primaire 2 du tableau de données"

