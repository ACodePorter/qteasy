msgstr ""
"Un objet data_source, la valeur par défaut est None. Si aucun, affichez "
"l'aperçu de la source de données par défaut."

#: of qteasy.core.get_data_overview:7 qteasy.core.get_table_overview:5
msgid "需要显示overview的数据表名称，如果为None，则显示所有数据表的overview"
msgstr ""
"Si fourni, affichez l'aperçu de la table de données, si aucun, affichez "
"l'aperçu de toutes les tables de données."

#: of qteasy.core.get_data_overview:9 qteasy.core.get_table_overview:7
