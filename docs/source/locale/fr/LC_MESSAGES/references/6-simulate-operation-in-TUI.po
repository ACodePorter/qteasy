msgid "`live_trading/3-risk-and-order-lifecycle.md`"
msgstr "`live_trading/3-risk-and-order-lifecycle.md`"

#: ../../source/references/6-simulate-operation-in-TUI.md
msgid "日志排障"
msgstr "Dépannage du journal"

#: ../../source/references/6-simulate-operation-in-TUI.md
msgid "`live_trading/5-artifacts-and-troubleshooting.md`"
msgstr "`live_trading/5-artifacts-and-troubleshooting.md`"

#: ../../source/references/6-simulate-operation-in-TUI.md
msgid "完整实操路径"
msgstr "Parcours pratique complet"

#: ../../source/references/6-simulate-operation-in-TUI.md
msgid "`tutorials/8-live-trade-risk-and-broker-walkthrough.md`"
msgstr "`tutorials/8-live-trade-risk-and-broker-walkthrough.md`"

#: ../../source/references/6-simulate-operation-in-TUI.md:44
msgid "5. 跳转导航"
msgstr "5. Navigation"

#: ../../source/references/6-simulate-operation-in-TUI.md:46
msgid "配置与运行：`live_trading/2-configuration-and-run.md`"
msgstr "Configurer et exécuter : `live_trading/2-configuration-and-run.md`"

#: ../../source/references/6-simulate-operation-in-TUI.md:47
msgid "生命周期：`live_trading/3-risk-and-order-lifecycle.md`"
msgstr "Cycle de vie : `live_trading/3-risk-and-order-lifecycle.md`"

