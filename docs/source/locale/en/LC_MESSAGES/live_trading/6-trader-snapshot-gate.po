#: ../../source/live_trading/6-trader-snapshot-gate.rst:112
msgid "diagnose_pending_orders 输出字段（简要）"
msgstr "diagnose_pending_orders output fields (brief)"

#: ../../source/live_trading/6-trader-snapshot-gate.rst:114
msgid "``local_pending_count`` — 本地在途单数"
msgstr "`local_pending_count` — Local pending count"

#: ../../source/live_trading/6-trader-snapshot-gate.rst:115
msgid "``remote_pending_count`` — 远端在途单数（simulator 常为空）"
msgstr ""
"``remote_pending_count` — Odd number of remote pending requests "
"(simulator is usually empty)"

#: ../../source/live_trading/6-trader-snapshot-gate.rst:116
msgid ""
"``local_pending_without_broker_order_id`` — 已提交但缺券商号的本地单"
msgstr ""
"``local_pending_without_broker_order_id`` — Local orders submitted but "
"lacking broker ID"

#: ../../source/live_trading/6-trader-snapshot-gate.rst:117
msgid "``local_pending_missing_remote`` — 本地有券商号但远端不存在"
msgstr ""
"`local_pending_missing_remote` — A brokerage account exists locally but "
"not remotely."

#: ../../source/live_trading/6-trader-snapshot-gate.rst:118
msgid "``remote_pending_not_in_local`` — 远端有、本地未映射"
msgstr ""
"`remote_pending_not_in_local` — Mapped on the remote end but not on the "
"local end."

#: ../../source/live_trading/6-trader-snapshot-gate.rst:121
msgid "CLI 与 DEBUG（运维）"
msgstr "CLI and DEBUG (Operations and Maintenance)"

#: ../../source/live_trading/6-trader-snapshot-gate.rst:123
msgid "Trader Shell（``--ui cli``）常用命令（help 为英文）："
msgstr ""
"Trader Shell (`--ui cli`) commonly used commands (help is in English):"

#: ../../source/live_trading/6-trader-snapshot-gate.rst:125
msgid "``gate`` / ``startup-gate`` — 手动跑启动门禁"
msgstr ""
"`gate` / `startup-gate` — Manually run the gate control startup process."

#: ../../source/live_trading/6-trader-snapshot-gate.rst:126
msgid "``reconcile`` / ``snapshot-reconcile`` — 对账 JSON"
msgstr "`reconcile` / `snapshot-reconcile` — Reconciliation JSON"

#: ../../source/live_trading/6-trader-snapshot-gate.rst:127
msgid "``run --task diagnose_pending_orders`` — 在途单诊断（需 **DEBUG**）"
msgstr ""
"`run --task diagnose_pending_orders` — Diagnose pending orders (requires "
"**DEBUG**)"

