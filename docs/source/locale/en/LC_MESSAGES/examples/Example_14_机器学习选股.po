msgid "机器学习选股策略（教学骨架版）"
msgstr ""
"Machine Learning Stock Selection Strategies (Teaching Framework)"

#: ../../source/examples/Example_14_机器学习选股.md:3
msgid ""
"参考来源：`docs/_joinquant_migration_source/Example_14_机器学习选"
"股.ipynb` 第一个 Markdown cell。"
msgstr ""
